{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 125,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": true,
	"arrowParens": "always",
	"requirePragma": false,
	"insertPragma": false,
	"proseWrap": "always",
	"sortPackageJson": false,
	"ignorePatterns": ["node_modules/", "bun.lockb", ".agents/"]
}
