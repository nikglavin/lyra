#!/usr/bin/env bash
# Lyra install script
# Usage (local):  ./install
# Usage (curl):   curl -fsSL https://raw.githubusercontent.com/nikglavin/lyra/main/install | bash

set -euo pipefail

REPO_URL="https://github.com/nikglavin/lyra.git"
INSTALL_DIR="${LYRA_DIR:-$HOME/.lyra}"

# Resolve repo root — either we're running from a clone, or we need to clone
if [ -n "${BASH_SOURCE[0]:-}" ] && [ -f "${BASH_SOURCE[0]}" ]; then
  REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
  # Piped from curl — clone the repo
  echo "Cloning Lyra into $INSTALL_DIR..."
  if [ -d "$INSTALL_DIR/.git" ]; then
    echo "Existing install found — updating..."
    git -C "$INSTALL_DIR" pull --tags -q
  else
    git clone --depth=1 "$REPO_URL" "$INSTALL_DIR"
  fi
  REPO_ROOT="$INSTALL_DIR"
fi

echo "Lyra install"
echo "  Repo: $REPO_ROOT"
echo ""

# Symlink public skills into ~/.claude/skills/
mkdir -p "$HOME/.claude/skills"
linked=0
skipped=0

for skill_dir in "$REPO_ROOT/.agents/skills"/*/; do
  skill_dir="${skill_dir%/}"  # strip trailing slash
  skill_name=$(basename "$skill_dir")
  target="$HOME/.claude/skills/$skill_name"

  if [ -d "$target" ] && [ ! -L "$target" ]; then
    echo "SKIP $skill_name — real directory exists at $target (not overwriting)"
    skipped=$((skipped + 1))
    continue
  fi

  ln -snf "$skill_dir" "$target"
  echo "Linked: $skill_name"
  linked=$((linked + 1))
done

# Install shared scripts
mkdir -p "$HOME/.claude/shared"
if [ -d "$HOME/.claude/shared/scripts" ] && [ ! -L "$HOME/.claude/shared/scripts" ]; then
  echo "SKIP shared/scripts — real directory exists at $HOME/.claude/shared/scripts (not overwriting)"
else
  ln -snf "$REPO_ROOT/lib/preflight/scripts" "$HOME/.claude/shared/scripts"
fi

echo ""
echo "Done. $linked skill(s) linked."
if [ "$skipped" -gt 0 ]; then
  echo "$skipped skill(s) skipped (real directories — remove manually to relink)."
fi
