{
	"name": "lyra",
	"version": "0.1.1",
	"description": "A skill library for Claude Code",
	"type": "module",
	"scripts": {
		"build": "bun scripts/build.ts",
		"deploy": "./scripts/bash/deploy.sh",
		"format:check": "oxfmt --check",
		"format:sh": "bun scripts/lint-sh.ts --write",
		"format": "oxfmt --write",
		"link": "./install",
		"lint:sh": "bun scripts/lint-sh.ts",
		"lint:skills": "bun scripts/lint-skill.ts",
		"lint:ts": "oxlint scripts/ test/",
		"lint": "bun run lint:ts && bun run lint:sh && bun run lint:skills",
		"setup-hooks": "ln -sf \"$(git rev-parse --show-toplevel)/scripts/bash/pre-commit.sh\" .git/hooks/pre-commit && echo 'pre-commit hook installed'",
		"test": "bun test",
		"typecheck": "bun x tsc"
	},
	"engines": {
		"bun": ">=1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@wasm-fmt/shfmt": "^0.2.6",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"shellcheck": "^4.1.0",
		"yaml": "^2.8.3"
	}
}
